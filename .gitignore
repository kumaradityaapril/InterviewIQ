# =========================================================================
# InterviewIQ - Root .gitignore
# Covers both Frontend (Vite/React) and Backend (Node/Express)
# =========================================================================

# --- Dependency Directories ---
node_modules/
jspm_packages/
web_modules/

# --- Build Outputs and Cache ---
dist/
dist-ssr/
build/
.next/
out/
.nuxt/
.cache/
.parcel-cache/
.turbo/

# --- Environment and Secret Files ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.local

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Editor and IDE Configurations ---
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

# --- OS Metadata ---
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
